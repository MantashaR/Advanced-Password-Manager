{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Password Manager",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/password_manager.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Generate password (gen)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/password_manager.py",
      "args": ["gen", "--length", "24"],
      "console": "integratedTerminal"
    }
  ]
}
